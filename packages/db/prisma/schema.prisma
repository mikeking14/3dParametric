datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  role         String   @default("USER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  models    Model[]
  downloads Download[]
}

model Model {
  id             String   @id @default(cuid())
  title          String
  description    String
  slug           String   @unique
  sourceType     String
  sourceFile     String
  paramManifest  String
  thumbnailUrl   String?
  previewMeshUrl String?
  licenseType    String
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sellerId  String
  seller    User       @relation(fields: [sellerId], references: [id])
  downloads Download[]
  tags      Tag[]
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  models Model[]
}

model Download {
  id        String   @id @default(cuid())
  format    String
  params    String?
  createdAt DateTime @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  modelId String
  model   Model  @relation(fields: [modelId], references: [id])
}

model ExportJob {
  id         String   @id @default(cuid())
  status     String   @default("PENDING")
  format     String
  params     String
  resultPath String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  modelId String
}
